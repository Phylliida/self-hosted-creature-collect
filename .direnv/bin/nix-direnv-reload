#!/usr/bin/env bash
set -e
if [[ ! -d "/home/bepis/prog/verus-cad/self-hosted-creature-collect" ]]; then
  echo "Cannot find source directory; Did you move it?"
  echo "(Looking for "/home/bepis/prog/verus-cad/self-hosted-creature-collect")"
  echo 'Cannot force reload with this script - use "direnv reload" manually and then try again'
  exit 1
fi

# rebuild the cache forcefully
_nix_direnv_force_reload=1 direnv exec "/home/bepis/prog/verus-cad/self-hosted-creature-collect" true

# Update the mtime for .envrc.
# This will cause direnv to reload again - but without re-building.
touch "/home/bepis/prog/verus-cad/self-hosted-creature-collect/.envrc"

# Also update the timestamp of whatever profile_rc we have.
# This makes sure that we know we are up to date.
touch -r "/home/bepis/prog/verus-cad/self-hosted-creature-collect/.envrc" "/home/bepis/prog/verus-cad/self-hosted-creature-collect/.direnv"/*.rc
